# API Configuration
REACT_APP_API_BASE_URL=http://localhost:8000
REACT_APP_API_VERSION=v1

# Environment
REACT_APP_ENVIRONMENT=development
REACT_APP_DEBUG=true

# Features Flags
REACT_APP_ENABLE_PREMIUM_FEATURES=false
REACT_APP_ENABLE_AFFILIATE_TRACKING=true

# Analytics (placeholder for future implementation)
REACT_APP_GOOGLE_ANALYTICS_ID=
REACT_APP_MIXPANEL_TOKEN=

# Sentry Error Tracking (placeholder)
REACT_APP_SENTRY_DSN=

# P2P Platform URLs
REACT_APP_SPORTTRADE_URL=https://sporttrade.com
REACT_APP_PROPHETX_URL=https://prophetx.com
REACT_APP_NOVIG_URL=https://novig.com

# Sportsbook URLs (for affiliate links)
REACT_APP_DRAFTKINGS_URL=https://sportsbook.draftkings.com
REACT_APP_FANDUEL_URL=https://sportsbook.fanduel.com
REACT_APP_CAESARS_URL=https://www.caesars.com/sportsbook

# UI Configuration
REACT_APP_DEFAULT_REFRESH_INTERVAL=30000
REACT_APP_ENABLE_NOTIFICATIONS=true 