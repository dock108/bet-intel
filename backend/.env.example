# Database Configuration
DATABASE_URL=sqlite:///./bet_intel.db

# API Keys
PINNACLE_API_KEY=your_pinnacle_api_key_here
PROPHETX_API_KEY=your_prophetx_api_key_here
SPORTTRADE_API_KEY=your_sporttrade_api_key_here
ODDS_API_KEY=your_odds_api_key_here

# Sportsbook URLs (for scraping)
DRAFTKINGS_BASE_URL=https://sportsbook.draftkings.com
FANDUEL_BASE_URL=https://sportsbook.fanduel.com
CAESARS_BASE_URL=https://www.caesars.com/sportsbook

# Redis Configuration (for caching and task queue)
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Environment
ENVIRONMENT=development
DEBUG=True

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate Limiting
API_RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO

# Affiliate Settings
AFFILIATE_TRACKING_ENABLED=True
DRAFTKINGS_AFFILIATE_ID=your_dk_affiliate_id
FANDUEL_AFFILIATE_ID=your_fd_affiliate_id
CAESARS_AFFILIATE_ID=your_caesars_affiliate_id

# AI/ML Settings
ENABLE_PREMIUM_FEATURES=False
MONTE_CARLO_ITERATIONS=10000
BAYESIAN_CONFIDENCE_THRESHOLD=0.8 